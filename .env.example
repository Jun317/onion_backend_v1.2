# ============================================================================
# onion_backend_v1.2 환경변수
# 복사: cp .env.example .env  후 값 채우기. (.env 는 커밋 금지)
# GitHub Actions 에서는 동일 이름으로 repo Secrets 에 등록한다.
# ============================================================================

# --- 한국 공시 (OpenDART, 무료키 즉시 발급: opendart.fss.or.kr) ---
DART_API_KEY=

# --- 한국은행 ECOS (ecos.bok.or.kr/api, 발급 ~1일) ---
ECOS_API_KEY=

# --- 미 연준 FRED (fred.stlouisfed.org/docs/api/api_key.html, 즉시) ---
FRED_API_KEY=

# --- LLM 이슈 가공 ---
# 1순위: Google AI Studio Gemini 키 (aistudio.google.com, 즉시)
GEMINI_API_KEY=
# 폴백: Groq (console.groq.com, 즉시)
GROQ_API_KEY=

# --- [선택] 공공데이터포털 주식시세 (kospi_close 차트용, 없으면 자동 skip) ---
DATA_GO_KR_API_KEY=

# --- 수집기 식별 User-Agent (SEC EDGAR 필수 — 연락처 포함 권장) ---
ONION_USER_AGENT=onion-backend/1.2 (contact: junsangpark317@gmail.com)

# --- [선택] 오버라이드 ---
# GEMINI_MODEL=gemini-2.5-flash-lite
# GROQ_MODEL=llama-3.3-70b-versatile
# EMBEDDING_BACKEND=st        # st(실모델) | fake(테스트용)
