 "glossary": [
  {
   "term": "중앙은행",
   "easy": "나라의 돈을 관리하고 이자율을 정하는 특별한 은행이에요.",
   "example": "우리나라는 한국은행, 미국은 연준이 여기예요."
  },
  {
   "term": "금리",
   "easy": "돈을 빌리거나 맡길 때 붙는 이자의 비율이에요.",
   "example": "높을수록 이자를 더 내거나 더 받아요."
  },
  {
   "term": "기준금리",
   "easy": "나라 전체 이자의 '기준점'이 되는 값이에요.",
   "example": "이게 오르면 내 대출 이자도 대체로 같이 올라요."
  },
  {
   "term": "유럽 중앙은행",
   "easy": "유럽 연합 국가들의 통화를 관리하는 중앙은행이에요.",
   "example": "유럽 중앙은행이 금리를 올리면 유럽 국가들의 대출 이자가 올라요."
  }
 ],
